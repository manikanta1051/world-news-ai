# ============================================================
# World News AI - Environment Configuration Example
# ============================================================
#
#
# PowerShell:
# Copy-Item .env.example .env
#
# ============================================================


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

APP_NAME=World News AI
APP_ENV=development
APP_DEBUG=true


# ------------------------------------------------------------
# AWS Configuration
# ------------------------------------------------------------

# AWS region used by the application
AWS_REGION=us-east-1

# AWS CLI / IAM Identity Center profile configured locally
AWS_PROFILE=world-news-dev


# ------------------------------------------------------------
# Amazon S3 Data Lake
# ------------------------------------------------------------

# Enter only the S3 bucket name, not an s3:// URL
# Example:
# AWS_S3_DATA_BUCKET=world-news-ai-data-dev-123456789012
AWS_S3_DATA_BUCKET=

# Folder prefixes inside the S3 bucket
AWS_S3_RAW_PREFIX=raw/news
AWS_S3_PROCESSED_PREFIX=processed/news
AWS_S3_REJECTED_PREFIX=rejected/news
AWS_S3_CURATED_PREFIX=curated/news
AWS_S3_SOCIAL_CARDS_PREFIX=social-cards


# ------------------------------------------------------------
# Amazon RDS PostgreSQL
# ------------------------------------------------------------

# AWS Secrets Manager secret containing the RDS credentials.
# Keep this blank until the RDS secret is created.
#
# Example:
# AWS_RDS_SECRET_ID=world-news-ai/dev/postgres
AWS_RDS_SECRET_ID=

# PostgreSQL connection details
#
# For local PostgreSQL development:
# POSTGRES_HOST=localhost
#
# For Amazon RDS:
# POSTGRES_HOST=your-database.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
POSTGRES_HOST=

POSTGRES_PORT=5432
POSTGRES_DB=world_news
POSTGRES_USER=
POSTGRES_PASSWORD=

# Use "require" for Amazon RDS.
# Local PostgreSQL may use "disable" if SSL is not configured.
POSTGRES_SSL_MODE=require

# SQLAlchemy configuration
POSTGRES_ECHO=false
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10


# ------------------------------------------------------------
# News Sources
# ------------------------------------------------------------

GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc

# Create a key from your selected news API provider.
# Keep blank when only using GDELT.
NEWS_API_KEY=


# ------------------------------------------------------------
# AI Service
# ------------------------------------------------------------

# Groq API key used for summaries, classifications,
# translations, and other AI features
GROQ_API_KEY=


# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------

LOG_LEVEL=INFO
LOG_FILE=logs/world_news_ai.log


# ------------------------------------------------------------
# HTTP Client
# ------------------------------------------------------------

HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_CONNECTIONS=20
HTTP_MAX_KEEPALIVE_CONNECTIONS=10
HTTP_RETRY_ATTEMPTS=3
HTTP_RETRY_MIN_WAIT_SECONDS=1
HTTP_RETRY_MAX_WAIT_SECONDS=5
HTTP_USER_AGENT=World-News-AI/0.1
